# Copy to .env and fill in your own values
# IMPORTANT: Do NOT commit your real .env (it contains secrets)

# MongoDB connection string
MONGO_URI=

# JWT signing secret
JWT_SECRET=

# NetEaseCloudMusicApi base URL (for the built-in music player)
# You must run a NetEaseCloudMusicApi instance yourself (recommended), or use a public instance if available.
# Example:
# MUSIC_API_BASE=http://127.0.0.1:3001
# Optional fallbacks (comma-separated, tried in order):
# MUSIC_API_BASES=http://127.0.0.1:3001,http://mrzym.top:3000
MUSIC_API_BASE=http://mrzym.top:3000
# Proxy timeout (ms) for /api/wapi/* requests
# MUSIC_PROXY_TIMEOUT_MS=25000

# AI provider
AI_API_KEY=
AI_MODEL=glm-4.6
# Optional: override OpenAI-compatible base URL
# AI_API_BASE=https://open.bigmodel.cn/api/paas/v4/chat/completions

# Local chord model service (FastAPI)
# Example: AI_CHORD_SERVICE_URL=http://127.0.0.1:8001
AI_CHORD_SERVICE_URL=

# Optional: server port
# PORT=3000

# Frontend (Vite)
# VITE_API_ORIGIN=http://localhost:3000
# VITE_REQUEST_TIMEOUT=10000
# VITE_ERROR_REPORTING=true

# Server logging
# CLIENT_ERROR_LOGGING=true

# Super Admin (server 启动后自动创建/提权)
# 说明：项目当前是“明文密码”登录机制；请使用强密码并妥善保管 .env
SUPER_ADMIN_EMAIL=superadmin@museai.local
SUPER_ADMIN_PASSWORD=SuperAdmin@123456
SUPER_ADMIN_USERNAME=Super Admin
